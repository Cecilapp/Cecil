{%- if page.translations|default({})|length >= 1 -%}
  {%- for alternate in page.translations ~%}
    <link rel="alternate" hreflang="{{ alternate.language }}" href="{{ url(alternate, {canonical: true}) }}">
  {%- endfor ~%}
  {#- default language -#}
  {%- set defaultLanguage = config.language|default(site.language) -%}
  {%- set defaultPage = page -%}
  {%- if page.language|default != defaultLanguage -%}
    {%- set translatedDefaultPage = page.translations|filter(translation => translation.language == defaultLanguage)|first -%}
    {%- if translatedDefaultPage is not empty -%}
      {%- set defaultPage = translatedDefaultPage -%}
    {%- endif -%}
  {%- endif ~%}
    <link rel="alternate" hreflang="x-default" href="{{ url(defaultPage, {canonical: true}) }}">
{%- endif -%}