# {{ site.title }}

{# description of the site #}
> {{ site.description|trim }}
{# section of the site #}
{% for section in site.pages.showable|filter(p => p.type == 'section') %}
{% set pages = section.pages|sort_by_weight %}
{# only show the section if it has pages #}
{% if pages|length > 0 ~%}
## {{ section.title|trim }}

{# pages of the section #}
{% for page in pages %}
{% if 'markdown' in page.output %}{% set page_output = 'markdown' %}{% else %}{% set page_output = 'html' %}{% endif %}
- [{{ page.title }}]({{ url(page, {format: page_output, canonical: true}) }}){% if page.description|default %}: {{ page.description|trim }}{% endif ~%}
{% endfor %}
{% endif %}
{% endfor %}